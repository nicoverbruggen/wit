{
  "name": "wit",
  "version": "0.2.0",
  "description": "Minimalist desktop writing app for plain text projects.",
  "main": "dist/main/main.js",
  "author": "Nico Verbruggen",
  "homepage": "https://nicoverbruggen.be",
  "license": "MIT",
  "scripts": {
    "clean": "rimraf dist release icon.png",
    "build:icon": "rsvg-convert -w 1024 -h 1024 icon.svg -o icon.png",
    "build:renderer": "esbuild src/renderer/renderer.ts --bundle --platform=browser --format=esm --target=es2022 --outfile=dist/renderer/renderer.js",
    "copy:renderer": "copyfiles -u 2 \"src/renderer/**/*.html\" \"src/renderer/**/*.css\" \"src/renderer/assets/**/*\" dist/renderer",
    "copy:font": "copyfiles -u 1 \"font/**/*\" dist/renderer/font",
    "copy:inter": "copyfiles -f \"node_modules/@fontsource/inter/files/inter-latin-400-normal.woff2\" \"node_modules/@fontsource/inter/files/inter-latin-400-italic.woff2\" \"node_modules/@fontsource/inter/files/inter-latin-500-normal.woff2\" \"node_modules/@fontsource/inter/files/inter-latin-500-italic.woff2\" \"node_modules/@fontsource/inter/files/inter-latin-600-normal.woff2\" \"node_modules/@fontsource/inter/files/inter-latin-600-italic.woff2\" \"node_modules/@fontsource/inter/files/inter-latin-700-normal.woff2\" \"node_modules/@fontsource/inter/files/inter-latin-700-italic.woff2\" dist/renderer/vendor/inter",
    "copy:material-symbols": "copyfiles -f \"node_modules/@material-symbols/font-400/material-symbols-outlined.woff2\" dist/renderer/vendor/material-symbols",
    "build": "npm run clean && tsc -p tsconfig.main.json && npm run build:renderer && npm run copy:renderer && npm run copy:font && npm run copy:inter && npm run copy:material-symbols",
    "start": "npm run build && electron .",
    "dev": "npm run start",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test:core": "npm run build && node --test tests/core/**/*.test.mjs",
    "test:e2e": "npm run build && playwright test",
    "test": "npm run test:core && npm run test:e2e",
    "dist": "npm run build && npm run build:icon && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "dist:mac": "npm run build && npm run build:icon && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "dist:linux": "npm run build && npm run build:icon && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --linux",
    "dist:win": "npm run build && npm run build:icon && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win"
  },
  "build": {
    "appId": "com.wit.app",
    "productName": "Wit",
    "icon": "icon.svg",
    "files": [
      "dist/**/*",
      "package.json",
      "icon.svg"
    ],
    "directories": {
      "output": "release"
    },
    "asar": true,
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "identity": null,
      "icon": "icon.png"
    },
    "linux": {
      "target": "AppImage",
      "category": "Office",
      "icon": "icon.svg"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.svg"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@playwright/test": "^1.54.2",
    "@types/node": "^22.15.2",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "copyfiles": "^2.4.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.28.0",
    "eslint": "^9.24.0",
    "globals": "^15.15.0",
    "playwright": "^1.54.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@fontsource/inter": "^5.2.8",
    "@material-symbols/font-400": "^0.44.0"
  }
}
